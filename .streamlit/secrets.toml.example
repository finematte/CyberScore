# Copy to secrets.toml and fill in real values. Do NOT commit secrets.toml.
# On Streamlit Community Cloud: paste this structure in App → Settings → Secrets.
#
# WHERE DOES THE DATA COME FROM?
# ------------------------------
# [database].url
#   - Local / quick test: use "sqlite:///./cyberscore.db" (no signup).
#   - Production / Cloud: use a MySQL URL. You get the values from your
#     database provider when you create a database (e.g. PlanetScale, Railway,
#     Aiven, or your own server). They give you: host, port, database name,
#     username, password. Format: mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE
#
# [secrets].secret_key
#   - You invent this. Any random string at least 32 characters long.
#   - Generate one: python -c "import secrets; print(secrets.token_hex(32))"
#   - Do not share it or commit it to git.
#
# Option A: Direct database URL
[database]
url = "sqlite:///./cyberscore.db"
# Production (MySQL): url = "mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE"

# Option B: MySQL in Streamlit connections format (used if [database].url is not set)
# [connections.mysql]
# host = "your-mysql-host"
# port = 3306
# database = "cyberscore"
# username = "your-user"
# password = "your-password"

[secrets]
secret_key = "your-secret-key-at-least-32-characters-long"
